{
  "manifest_version": 3,
  "name": "週末・祝日通知",
  "version": "1.0.0",
  "description": "週末・祝日にブラウザを開いたとき、1日1回バナー通知します",
  "permissions": [
    "notifications",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "1038811287294-7j4fhrv8vic7hjlig6le8strbrnjhe1g.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events.readonly"
    ]
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "key": ""
}
